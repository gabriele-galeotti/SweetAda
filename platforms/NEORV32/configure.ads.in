
package Configure
   with Pure => True
   is

   -- PLATFORM and CPU definitions
   PLATFORM    : constant String := "@PLATFORM@";
   SUBPLATFORM : constant String := "@SUBPLATFORM@";
   CPU         : constant String := "@CPU@";
   CPU_MODEL   : constant String := "@CPU_MODEL@";

   -- basic configuration parameters
   TICK_FREQUENCY : constant := 1_000;
   MTIME_ADDRESS    : constant := 16#FFF4_BFF8#;
   MTIMECMP_ADDRESS : constant := 16#FFF4_4000#;

end Configure;
