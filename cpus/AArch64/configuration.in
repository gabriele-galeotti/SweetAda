
TOOLCHAIN_NAME := $(TOOLCHAIN_NAME_AArch64)

ifeq      ($(CPU_MODEL),Cortex-A53)
  CPU_DEF := cortex-a53.def
else ifeq ($(CPU_MODEL),Cortex-A520)
  CPU_DEF := cortex-a520.def
endif
export CPU_DEF

GNATPREP_FILES          += $(CPU_DIRECTORY)/armv8a.ads \
                           $(CPU_DIRECTORY)/armv8a.adb
GNATPREP_DEFINES_armv8a := $(CPU_DIRECTORY)/$(CPU_DEF)

GPR_CORE_CPU += cpu.ads    \
                armv8a.adb \
                armv8a.ads

